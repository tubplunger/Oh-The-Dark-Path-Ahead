--- !u!114 &2005565900167241500
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2060519101664691459}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 653ab51685760c8429a53d562a75958c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  letterTitle: My Dearest Star
  letterBody: 'If you are reading this I have likely been gone for a long time. Locking
    you away in here is a cruetly, but it is a greater cruetly for you to experience
    the rot and decay our world has become.

    I know you can''t stay there forever
    though, even if I am unable to be there. At the bottom of our home is the key
    to unlock the front door, though to get there you need to past some tests I have
    set up for you.

    If you get through them all then I beg you to run as far
    as you can away from here. Do not try to follow my own path, for I fear you will
    share whatever fate I get.'
  interactIcon: {fileID: 6141003982414712230}
