--- !u!1001 &1563224100
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 2005565900167241500, guid: fefab22b10384ab4080c363d18d153eb, type: 3}
      propertyPath: letterBody
      value: 'And here you are now. I hope my little test course has prepared you
        enough for the outside, though I can never prepare you for what our old neighbors
        and fellow villagers have become out there. I am telling you right now to
        avoid them as best as you can, and don''t let them grab you!


        And
        once again, I beg of you, to find your own path out of these now cursed lands!
        Do not follow the path I took, for if you are reading these it is likely
        that the path I took has led to nothing.


        I love you, my little
        Star.'
      objectReference: {fileID: 0}
    - target: {fileID: 2060519101664691459, guid: fefab22b10384ab4080c363d18d153eb, type: 3}
      propertyPath: m_Name
